# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=slotsy
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRY_HOURS=24

# ── Gmail SMTP ────────────────────────────────────────────
# Use a Gmail App Password (NOT your login password)
# Steps: myaccount.google.com → Security → App Passwords → Create
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── App ───────────────────────────────────────────────────
APP_NAME=SlotSync
FRONTEND_URL=http://127.0.0.1:5500
FLASK_DEBUG=true
